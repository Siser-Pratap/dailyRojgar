# ─────────────────────────────────────────────────────────────────────────────
# dailyRojgar — Environment Variables Template
# Copy this file to .env.development, .env.test, or .env.production
# and fill in the actual values. NEVER commit real values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/dailyrojgar
REDIS_URL=redis://localhost:6379

# ─── Auth (generate with: openssl rand -hex 32) ──────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Payment (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── File Storage (AWS S3) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=dailyrojgar-uploads

# ─── Email (SMTP / AWS SES) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dailyrojgar.in

# ─── SMS (MSG91) ─────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=DROJGR
MSG91_TEMPLATE_ID=

# ─── Monitoring (Sentry) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Client (prefix VITE_ so Vite exposes these to the browser) ──────────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_RAZORPAY_KEY_ID=
VITE_APP_NAME=dailyRojgar
